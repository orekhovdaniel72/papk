# Скопируй в .env.local и заполни. .env.local НЕ коммитится (см. .gitignore).
# Реальные значения появятся на Этапе 1+, когда заведём Supabase и R2.

# --- Supabase (Этап 1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (Этап 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- App ---
# Базовый URL приложения (для генерации ссылок шаринга)
NEXT_PUBLIC_APP_URL=http://localhost:3000
